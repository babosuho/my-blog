---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  url: string;
  image?: string;
}

const { title, description, pubDate, updatedDate, url, image } = Astro.props;

const siteUrl = 'https://my-blog-pages-a94.pages.dev';

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": pubDate.toISOString(),
  "dateModified": (updatedDate || pubDate).toISOString(),
  "url": url,
  "author": {
    "@type": "Person",
    "name": "바보수호",
    "alternateName": "BaboSuho",
    "url": `${siteUrl}/about`,
    "jobTitle": "디지털마케팅/웹개발/웹디자인 전문가",
    "description": "디지털 기술로 세상을 연결하는 전문가"
  },
  "publisher": {
    "@type": "Organization",
    "name": "바보수호",
    "url": siteUrl
  },
  ...(image ? { "image": `${siteUrl}${image}` } : {})
};
---

<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />