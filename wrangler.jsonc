{
	"main": "dist/_worker.js/index.js",
	"name": "my-blog",
	"compatibility_date": "2026-02-26",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
		"enabled": true
	},
	"vars": {
		"GITHUB_CLIENT_ID": "Ov23lit22zIP1HWCe7vv"
	},
	"secrets": ["GITHUB_CLIENT_SECRET"]
}
